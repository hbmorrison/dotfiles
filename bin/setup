#!/bin/bash

# Source OS release variables.

if [ -f /etc/os-release ]
then
  source /etc/os-release
fi

# Pretty feedback.

GOTO_COLUMN="\\033[72G"
RED='\033[00;31m'
GREEN='\033[00;32m'
YELLOW='\033[00;33m'
CLEAR='\033[00m'

notice () {
  echo -n "${1^} ... "
}
notice_yes () {
  echo -e "${GOTO_COLUMN}${GREEN}Yes${CLEAR}"
}
notice_no () {
  echo -e "${GOTO_COLUMN}${YELLOW}No${CLEAR}"
}
pass () {
  echo -e "${GOTO_COLUMN}${GREEN}Done${CLEAR}"
}
fail () {
  if [ -z ${1:+z} ]
  then
    echo -e "${GOTO_COLUMN}${YELLOW}Failed${CLEAR}"
  else
    echo -e "${GOTO_COLUMN}${RED}FAILED${CLEAR}"
    echo -e "${RED}Error:${CLEAR} ${1}"
    exit 1
  fi
  return 1
}
usage () {
  if [ ! -z ${1:+z} ]
  then
    echo -e "${RED}Usage:${CLEAR} setup" "$@"
    exit 1
  fi
}

# Locate the base directory of the repository.

THIS_SCRIPT=$(readlink -f $0)
BIN_DIR=$(dirname $THIS_SCRIPT)
BASE_DIR=$(dirname $BIN_DIR)
ETC_DIR="${BASE_DIR}/etc"
LOCAL_BIN="${HOME}/.local/bin"

# Check that symlink is set up.

if [ ! -d $LOCAL_BIN ]
then
  mkdir -p $LOCAL_BIN
fi

if [ -L $LOCAL_BIN/setup ]
then
  rm -f $LOCAL_BIN/setup
fi
ln -s $BIN_DIR/setup $LOCAL_BIN/setup

# Work out whether to run commands using sudo.

SUDO=sudo
if [ $(id -u) -eq 0 ]
then
  SUDO=""
fi

# Get the name of the setup script from the command line.

SCRIPT=""
if [ ! -z ${1:+z} ]
then
  SCRIPT=$1
  shift
fi

# Work out the path to the setup script.

SCRIPT_FILE="${BIN_DIR}/setup_${SCRIPT}.sh"
if [ ! -f $SCRIPT_FILE ]
then

  # Print a usage message listing all available setup scripts.

  AVAILABLE_SCRIPTS="("
  for FILE in $BIN_DIR/setup_*.sh
  do
    NAME=$(basename -s .sh $FILE | sed 's/^setup_//')
    AVAILABLE_SCRIPTS+="${NAME}|"
  done
  ARGS=$(echo $AVAILABLE_SCRIPTS | sed 's/|$/)/')
  usage "${ARGS}"
fi

# Run the setup script.

source ${SCRIPT_FILE} $*
